{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-signal-archive",
  "compatibility_date": "2026-04-19",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true
}
