---
import "@fontsource/newsreader/700.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@/styles/global.css";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { createBreadcrumbJsonLd, createWebsiteJsonLd, type BreadcrumbItem } from "@/lib/seo";
import { getSiteUrl, siteConfig, withBase } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
  noIndex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  jsonLd?: Record<string, unknown>[];
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  pathname = Astro.url.pathname,
  image = "/og/home.svg",
  noIndex = false,
  breadcrumbs = [],
  jsonLd = []
} = Astro.props;

const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const canonical = getSiteUrl(pathname);
const ld = [createWebsiteJsonLd(), ...(breadcrumbs.length ? [createBreadcrumbJsonLd(breadcrumbs)] : []), ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={getSiteUrl(image)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={getSiteUrl(image)} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    {ld.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <Header />
    {breadcrumbs.length > 0 && (
      <div class="shell">
        <Breadcrumbs items={breadcrumbs} />
      </div>
    )}
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
